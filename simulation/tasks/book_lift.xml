<mujoco model="exo_book_lift_task">
  <extension>
    <plugin plugin="mujoco.elasticity.cable"/>
  </extension>

  <include file="../myosuite/myosuite/simhive/myo_sim/arm/assets/myoarm_assets.xml"/>
  <include file="../myosuite/myosuite/simhive/furniture_sim/simpleTable/simpleTable_asset.xml"/>

  <compiler autolimits = "true" inertiafromgeom="auto" angle="radian" balanceinertia="true" boundmass="0.001" boundinertia=".0001" meshdir="../myosuite/myosuite/simhive/myo_sim" texturedir="../myosuite/myosuite/simhive/myo_sim/"/>
  <option timestep="0.002">
    <flag multiccd="enable"/>
  </option>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="1 1" texuniform="true"/>
  </asset>

  <worldbody>
    <geom name="ground" type="plane" size="0 0 1" material="matplane"/>
    <body name="table" pos="0 0 0">
      <include file="../myosuite/myosuite/simhive/furniture_sim/simpleTable/simpleWoodTable_body.xml"/>
    </body>
    <body name="book" pos="0 0 1">
      <freejoint name="book/freejoint"/>
      <geom type="box" size="0.1 0.15 0.02" rgba="0.8 0.1 0.1 1" contype="1" conaffinity="1"/>
      <inertial mass="2" pos="0 0 0" diaginertia="0.001 0.001 0.001"/> 
    </body>
    <body name = "subject" pos="0 0.5 1.25">
      <include file="../myosuite/myosuite/simhive/myo_sim/arm/assets/myoarm_body.xml"/>
    </body>
    <body name="exo" pos="-0.1292 0.4888 1.264" quat="0.5004 0.5 -0.5 -0.4996">
      <freejoint name="exo_freejoint"/>
      <body name="winch" pos="0 0 0.026">
        <joint name="winch"/>
        <geom type="cylinder" size="0.02 0.02" contype="0" conaffinity="0"/>
        <geom type="cylinder" size="0.04 0.002" pos="0 0 -0.022" contype="0" conaffinity="0"/>
        <body name="B0" pos="0 0 -0.022" euler="0 -0.034 -1.6018">
          <inertial mass="0.01" diaginertia="0.0001 0.0001 0.0001" pos="0 0 0"/>
          <joint type="ball"/>
          <composite prefix="actuated" type="cable" curve="s" count="100 1 1"
                      size="0.432 .015 1" offset="0 0 0" initial="ball">
              <joint kind="main" damping="0.15" armature="0.01"/>
              <geom type="capsule" size=".001" rgba="0 0 1 1"/>
          </composite>
        </body>        
      </body>
    </body>

  </worldbody>

  <equality>
    <!-- attachment: winch housing to scapula -->
    <connect body1="scapula" body2="winch" anchor="0 0.05 0" solref="0.01 1"/>
    <!-- Ball joint: cable end to mid-forearm on ulna -->
    <connect body1="ulna" body2="actuatedB_last" anchor="0.1 -0.12 0.02" solref="0.01 1"/>
  </equality>

  <actuator>
    <velocity name="winch" joint="winch" kv="200" ctrllimited="true" ctrlrange="-10 10"/>
  </actuator>
  <!-- Keyframe commented out: qpos size changed with addition of exo freejoint + cable DOFs.
       Regenerate after verifying model loads correctly.
  <keyframe>
    <key qpos="-1.16807e-13 -4.94653e-12 0.779892 1 -4.2889e-19 1.0275e-18 3.92572e-12 -0.0739106 0.0313022 -0.0313057 0.0739134 -0.0149502 0.120932 0.0543492 -0.0543492 -0.120934 0.0149585 1.29581 0.305419 -1.29581 -0.362313 0.705469 -0.368241 -0.175356 -0.470917 -0.50013 -0.41382 -0.400973 -0.566511 0.670543 -0.167964 0.704582 0.351711 0.98572 -0.261835 0.569455 0.123995 1.01967 -0.261843 0.377426 0.148416 0.872579 -0.261845 0.383963 0.0834824"/>
  </keyframe>
  -->

</mujoco>
